# ============================================
# VARIABLES DE ENTORNO - DESARROLLO
# ============================================
# COPIAR ESTE ARCHIVO COMO .env Y CONFIGURAR

# Database MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=your_mysql_password_here
DB_NAME=campus_virtual

# JWT Secrets (GENERAR NUEVOS EN PRODUCCIÓN)
JWT_SECRET=tu_secreto_jwt_super_seguro_cambiar_en_produccion_12345
JWT_REFRESH_SECRET=tu_secreto_refresh_jwt_super_seguro_cambiar_en_produccion_67890
JWT_EXPIRATION=3600
JWT_REFRESH_EXPIRATION=604800

# App Configuration
NODE_ENV=development
PORT=3000
API_PREFIX=api

# CORS Origins (separados por coma)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# Uploads
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads
